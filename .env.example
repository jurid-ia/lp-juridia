# API do Jurid IA Voice — usada pelo context/ApiContext.tsx para PostAPI, GetAPI, etc.
NEXT_PUBLIC_API_URL=https://voice-api.juridia.com.br

# Destino do redirect após o submit do form do hero/CTA.
# Padrão: página interna /parabens (botões de app iOS/Android/Web + WhatsApp).
# Para mandar direto para a tela de senha do produto, troque por https://voice.juridia.com.br/register.
NEXT_PUBLIC_REGISTER_URL=/parabens

# WhatsApp oficial usado nos CTAs da /parabens. Formato: código país + DDD + número, só dígitos.
# NEXT_PUBLIC_WHATSAPP_NUMBER=5541963475328

# -----------------------------------------------------------------------------
# Meta Pixel + Conversions API (CAPI)
# -----------------------------------------------------------------------------

# Pixel ID — público, vai pro cliente. Prefixo NEXT_PUBLIC_.
NEXT_PUBLIC_META_PIXEL_ID=

# Access Token da CAPI — SECRETO, só servidor. NUNCA commitar, NUNCA expor no cliente.
# Gerar via System User no Business Manager (tokens pessoais expiram).
# Events Manager → Pixel → Configurações → Conversions API → "Set up manually".
META_CAPI_ACCESS_TOKEN=

# Test Event Code — usado apenas em desenvolvimento (NODE_ENV !== 'production').
# Pegar em Events Manager → Testar Eventos.
META_CAPI_TEST_EVENT_CODE=

# Versão da Graph API. Atualizar a cada ~6 meses.
META_CAPI_API_VERSION=v21.0
